{
  "name": "transcribbler",
  "version": "0.1.0",
  "description": "Lokal app for kvalitativ transkript-kodning",
  "author": {
    "name": "Jonas Baath",
    "email": "jonas.baath@slu.se"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/JonasBaath/transcribbler.git"
  },
  "main": "main.js",
  "scripts": {
    "postinstall": "node postinstall.js",
    "start": "electron .",
    "prepare:runtime": "bash prepare-runtime.sh",
    "prebuild:mac": "bash prepare-runtime.sh",
    "prebuild:win": "bash prepare-runtime.sh",
    "prebuild:linux": "bash prepare-runtime.sh",
    "prebuild": "bash prepare-runtime.sh",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "build": "electron-builder -mwl"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "se.jonasbaaath.transcribbler",
    "productName": "Transcribbler",
    "directories": { "buildResources": "assets", "output": "dist" },
    "files": ["main.js", "preload.js", "assets/**/*"],
    "extraResources": [
      {
        "from": "../",
        "to": "app",
        "filter": ["main.py", "requirements.txt", "core/**/*", "static/**/*", "templates/**/*"]
      },
      {
        "from": "python-runtime",
        "to": "python-runtime",
        "filter": ["**/*"]
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/icon.icns",
      "target": [{ "target": "dmg", "arch": ["arm64", "x64"] }]
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": [{ "target": "nsis", "arch": ["x64"] }]
    },
    "linux": {
      "icon": "assets/icon.png",
      "target": [
        { "target": "AppImage", "arch": ["x64"] },
        { "target": "deb", "arch": ["x64"] }
      ],
      "category": "Science"
    }
  }
}
